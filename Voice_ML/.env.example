# ============================================================================
# Voice_ML (inference service) — environment template. Copy to `.env`.
# Keys use the VC_ prefix, read by app/core/config.py (pydantic-settings).
# This service runs ALL ML; the backend reaches it at VC_ML_SERVICE_URL.
# ============================================================================

# ---- Compute ---------------------------------------------------------------
# auto picks CUDA when available, else CPU.
VC_DEVICE=auto

# ---- ffmpeg ----------------------------------------------------------------
# Prod (Docker/Linux): ffmpeg is on PATH, so the names below work as-is.
# Local Windows example (static build):
#   VC_FFMPEG_PATH=C:/Users/you/tools/ffmpeg/bin/ffmpeg.exe
#   VC_FFPROBE_PATH=C:/Users/you/tools/ffmpeg/bin/ffprobe.exe
VC_FFMPEG_PATH=ffmpeg
VC_FFPROBE_PATH=ffprobe

# ---- Models (override only to pin/change) ----------------------------------
VC_ASR_MODEL=small
VC_TRANSLATION_MODEL=facebook/nllb-200-distilled-600M
VC_TTS_MODEL_EN=facebook/mms-tts-eng
VC_TTS_MODEL_NE=aryamanstha/speecht5_tts_nepali_oslr43_tokenizermodified

# ---- Phase 2-4 assets (paths inside the service) ---------------------------
VC_OPENVOICE_CKPT=./checkpoints_v2/converter
VC_WAV2LIP_DIR=./Wav2Lip
VC_WAV2LIP_CHECKPOINT=./Wav2Lip/checkpoints/wav2lip_gan.pth

# ---- HuggingFace cache (optional; persist across restarts in prod) ---------
# HF_HOME=/data/hf-cache
# HF_HUB_DISABLE_SYMLINKS_WARNING=1

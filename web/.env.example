# ============================================================================
# web (Next.js frontend) — environment template. Copy to `.env.local`.
#   - BACKEND_URL          : server-side; Next rewrites proxy /api/* → this (local same-origin)
#   - NEXT_PUBLIC_API_URL  : client-side API base. Empty = same-origin (use rewrites). Set to
#                            the backend origin for a split Vercel↔Render deploy.
#   - NEXT_PUBLIC_WS_URL   : websocket base (job progress). Usually = the backend origin.
# ============================================================================

# ---- LOCAL (same-origin via Next rewrites to the local backend) ------------
BACKEND_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=http://127.0.0.1:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- PRODUCTION (Vercel frontend → Render backend) -------------------------
# Set these in the Vercel project env (and keep backend VC_CORS_ORIGINS = the site URL).
# The frontend talks only to the backend; the backend reaches Voice_ML
# (https://linguasync-1.onrender.com) server-side.
# BACKEND_URL=https://linguasync-qjns.onrender.com
# NEXT_PUBLIC_API_URL=https://linguasync-qjns.onrender.com
# NEXT_PUBLIC_WS_URL=https://linguasync-qjns.onrender.com
# NEXT_PUBLIC_SITE_URL=https://lingua-sync-self.vercel.app

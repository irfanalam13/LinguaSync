# ============================================================================
# Voice_backend (API gateway) — environment template. Copy to `.env`.
# All keys use the VC_ prefix and are read by app/core/config.py (pydantic-settings).
# ============================================================================

# ---- Database --------------------------------------------------------------
# Local (default): SQLite. Prod: Postgres (postgresql:// is auto-normalized to
# postgresql+psycopg:// in app/db/base.py). NEVER commit a real password.
VC_DATABASE_URL=sqlite:///./voice_platform.db
# VC_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require&channel_binding=require

# ---- Redis / job queue -----------------------------------------------------
# Local: eager (inline, no Redis). Prod: rq + a Redis URL (run worker.py too).
VC_QUEUE_BACKEND=eager
VC_REDIS_URL=redis://localhost:6379/0

# ---- Object storage --------------------------------------------------------
# Local: local filesystem. Prod: minio (S3-compatible).
VC_STORAGE_BACKEND=local
VC_STORAGE_DIR=./storage_data
VC_MINIO_ENDPOINT=localhost:9000
VC_MINIO_ACCESS_KEY=minioadmin
VC_MINIO_SECRET_KEY=minioadmin
VC_MINIO_BUCKET=voice-platform
VC_MINIO_SECURE=false

# ---- Voice_ML inference service (the API connection between services) ------
# Local: the ML service on localhost. Prod: the Render-hosted ML URL.
VC_ML_SERVICE_URL=http://127.0.0.1:8001
# VC_ML_SERVICE_URL=https://linguasync-1.onrender.com
VC_ML_TIMEOUT_S=3600

# ---- Auth / JWT ------------------------------------------------------------
# Generate a strong value for prod, e.g. `python -c "import secrets;print(secrets.token_urlsafe(48))"`
VC_JWT_SECRET=change-me-in-production
VC_JWT_ALGORITHM=HS256
VC_ACCESS_TOKEN_TTL_MIN=30
VC_REFRESH_TOKEN_TTL_DAYS=14

# ---- CORS (frontend origins, JSON array) -----------------------------------
# Local: Next dev. Prod: the Vercel-hosted frontend.
VC_CORS_ORIGINS=["http://localhost:3000"]
# VC_CORS_ORIGINS=["https://lingua-sync-self.vercel.app"]

# ---- Uploads ---------------------------------------------------------------
VC_MAX_UPLOAD_MB=500
